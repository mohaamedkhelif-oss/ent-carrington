<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        body { font-family: 'Segoe UI', sans-serif; margin: 0; background: white; }
        .header { padding: 15px 30px; display: flex; align-items: center; border-bottom: 1px solid #ddd; }
        .calendar-grid { display: grid; grid-template-columns: repeat(7, 1fr); border-left: 1px solid #ddd; }
        .day-header { padding: 10px; text-align: center; background: #f8f9fa; border-right: 1px solid #ddd; border-bottom: 1px solid #ddd; font-weight: bold; }
        .day-cell { height: 150px; border-right: 1px solid #ddd; border-bottom: 1px solid #ddd; padding: 5px; }
        .event { background: #009cc3; color: white; padding: 4px; border-radius: 3px; font-size: 11px; margin-bottom: 2px; }
    </style>
</head>
<body>
    <div class="header">
        <button onclick="window.location='/'" style="border:none; background:none; cursor:pointer; font-size:20px; margin-right:20px;"><i class="fa fa-arrow-left"></i></button>
        <h2 style="margin:0;">Agenda - Mars 2024</h2>
    </div>

    <div class="calendar-grid">
        <div class="day-header">LUN</div><div class="day-header">MAR</div><div class="day-header">MER</div>
        <div class="day-header">JEU</div><div class="day-header">VEN</div><div class="day-header">SAM</div><div class="day-header">DIM</div>
        
        <% for(let i=1; i<=31; i++) { %>
            <div class="day-cell">
                <span style="color:#666;"><%= i %></span>
                <% if(i === 12) { %><div class="event">Réunion Direction</div><% } %>
                <% if(i === 15) { %><div class="event" style="background:#ff8c00;">Cours de Math</div><% } %>
            </div>
        <% } %>
    </div>
</body>
</html>