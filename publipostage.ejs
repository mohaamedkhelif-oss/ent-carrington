<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: sans-serif; padding: 20px; }
        .fiche { border: 2px dashed #009cc3; padding: 20px; width: 400px; margin-bottom: 20px; page-break-inside: avoid; }
        .logo { color: #009cc3; font-weight: bold; font-size: 24px; }
        @media print { .btn-print { display: none; } }
    </style>
</head>
<body>
    <button class="btn-print" onclick="window.print()">Imprimer les fiches</button>
    <h1>Fiches de connexion - Collège André Malraux</h1>

    <% users.forEach(u => { %>
        <div class="fiche">
            <div class="logo">neo</div>
            <h3>Fiche de connexion : <%= u.firstname %> <%= u.lastname %></h3>
            <p><strong>Identifiant :</strong> <%= u.username %></p>
            <p><strong>Mot de passe :</strong> <%= u.password %></p>
            <p style="font-size: 10px; color: #666;">Connectez-vous sur : http://localhost:3000/login</p>
        </div>
    <% }) %>
</body>
</html>