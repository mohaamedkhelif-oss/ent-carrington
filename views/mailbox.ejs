<!DOCTYPE html>
<html>
<head>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        :root { --blue: #009cc3; --orange: #ff8c00; }
        body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; margin: 0; }
        .nav { background: var(--blue); color: white; padding: 10px 30px; display: flex; justify-content: space-between; align-items: center; }
        .container { display: grid; grid-template-columns: 280px 1fr 280px; gap: 20px; padding: 20px; max-width: 1400px; margin: auto; }
        .card { background: white; border-radius: 12px; padding: 20px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); }
        
        /* Liste des mails */
        .mail-row { padding: 15px; border-bottom: 1px solid #eee; cursor: pointer; transition: 0.2s; }
        .mail-row:hover { background: #f8faff; transform: translateX(5px); }

        /* Autocomplete */
        #suggestions { border: 1px solid #ddd; background: white; position: absolute; width: 95%; z-index: 1000; display: none; border-radius: 8px; box-shadow: 0 5px 15px rgba(0,0,0,0.1); }
        .sugg-item { padding: 10px; cursor: pointer; border-bottom: 1px solid #f0f0f0; }
        .sugg-item:hover { background: #f0f7ff; color: var(--blue); }

        /* Modales */
        #overlay { display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.6); z-index:50; backdrop-filter: blur(3px); }
        .modal { display:none; position:fixed; top:15%; left:25%; width:50%; background:white; border-radius:15px; padding:30px; z-index:100; box-shadow: 0 20px 40px rgba(0,0,0,0.4); }
        
        .btn-compose { background: var(--orange); color: white; border: none; padding: 10px 20px; border-radius: 20px; cursor: pointer; font-weight: bold; width: 100%; margin-bottom: 20px; transition: 0.3s; }
        .btn-compose:hover { transform: scale(1.05); background: #e67e00; }
    </style>
</head>
<body>
    <div class="nav">
        <strong>Académie Fallon CARRINGTON</strong>
        <span><%= user.firstname %> <%= user.lastname %> <i class="fa fa-user-circle"></i></span>
    </div>

    <div class="container">
        <div class="card">
            <button class="btn-compose" onclick="openCompose()"><i class="fa fa-plus"></i> Nouveau message</button>
            <p style="text-align:center; color:#888;">Espace Dirigeant</p>
        </div>

        <div class="card">
            <h3 style="color:var(--blue); border-bottom: 2px solid #eee; padding-bottom:10px;">FIL DE NOUVEAUTÉS</h3>
            <% messages.forEach(m => { %>
                <div class="mail-row" onclick="readMail('<%= m.id %>')">
                    <strong><%= m.sender_name %></strong> <br>
                    <span style="color:#555;"><%= m.subject %></span>
                </div>
            <% }) %>
        </div>

        <div class="card">
            <h3 style="font-size:14px; color:#999;">APPLICATIONS</h3>
            <div style="display:grid; grid-template-columns:1fr 1fr; gap:10px;">
                <div class="app-btn" onclick="window.open('/agenda', '_blank')"><i class="fa fa-calendar-alt"></i><br>Agenda</div>
                <% if(user.role === 'admin') { %>
                    <div class="app-btn" onclick="window.open('/admin', '_blank')"><i class="fa fa-crown"></i><br>Admin</div>
                <% } %>
            </div>
        </div>
    </div>

    <div id="overlay" onclick="closeAll()"></div>
    <div id="reader" class="modal">
        <h2 id="vSub" style="color:var(--blue);"></h2>
        <p>Expéditeur : <strong id="vSen"></strong></p><hr>
        <div id="vCon" style="margin-top:20px; line-height:1.6; font-size:17px;"></div>
    </div>

    <div id="composer" class="modal">
        <h3>Nouveau message</h3>
        <form action="/send" method="POST">
            <div style="position:relative;">
                <input type="text" id="destSearch" placeholder="Destinataire (tapez les premières lettres...)" autocomplete="off" style="width:100%; padding:12px; border:1px solid #ddd; border-radius:8px;">
                <div id="suggestions"></div>
                <input type="hidden" name="to_username" id="to_username">
            </div>
            <input type="text" name="subject" placeholder="Objet" required style="width:100%; padding:12px; border:1px solid #ddd; border-radius:8px; margin: 15px 0;">
            <textarea name="content" placeholder="Votre message..." required style="width:100%; height:150px; padding:12px; border:1px solid #ddd; border-radius:8px;"></textarea>
            <button type="submit" class="btn-compose" style="margin-top:15px;">ENVOYER LE MESSAGE</button>
        </form>
    </div>

    <script>
        // Lecture Mail
        function readMail(id) {
            fetch('/mail/' + id).then(r => r.json()).then(data => {
                document.getElementById('vSub').innerText = data.subject;
                document.getElementById('vSen').innerText = data.sender_name;
                document.getElementById('vCon').innerText = data.content;
                document.getElementById('overlay').style.display = 'block';
                document.getElementById('reader').style.display = 'block';
            });
        }

        // Autocomplete
        const searchInput = document.getElementById('destSearch');
        const suggBox = document.getElementById('suggestions');
        const hiddenInput = document.getElementById('to_username');

        searchInput.addEventListener('input', function() {
            if(this.value.length < 1) { suggBox.style.display = 'none'; return; }
            fetch('/search-users?term=' + this.value).then(r => r.json()).then(users => {
                suggBox.innerHTML = '';
                if(users.length > 0) {
                    suggBox.style.display = 'block';
                    users.forEach(u => {
                        let div = document.createElement('div');
                        div.className = 'sugg-item';
                        div.innerHTML = `<i class="fa fa-user"></i> ${u.firstname} ${u.lastname}`;
                        div.onclick = () => {
                            searchInput.value = u.firstname + ' ' + u.lastname;
                            hiddenInput.value = u.username;
                            suggBox.style.display = 'none';
                        };
                        suggBox.appendChild(div);
                    });
                }
            });
        });

        function openCompose() { document.getElementById('overlay').style.display='block'; document.getElementById('composer').style.display='block'; }
        function closeAll() { document.getElementById('overlay').style.display='none'; document.getElementById('reader').style.display='none'; document.getElementById('composer').style.display='none'; }
    </script>
</body>
</html>